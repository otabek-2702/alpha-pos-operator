{
  "name": "alphapos-operator-link",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "prebuild": "expo prebuild --platform android --clean",
    "typecheck": "tsc --noEmit",
    "ios": "expo run:ios",
    "build:preview": "dotenv -e .env -- eas build --profile preview --platform android --non-interactive",
    "build:dev": "dotenv -e .env -- eas build --profile development --platform android --non-interactive",
    "build:prod": "dotenv -e .env -- eas build --profile production --platform android --non-interactive",
    "ota:preview": "dotenv -e .env -- eas update --branch preview",
    "ota:prod": "dotenv -e .env -- eas update --branch production"
  },
  "dependencies": {
    "@expo-google-fonts/hanken-grotesk": "^0.4.3",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-application": "~6.0.2",
    "expo-asset": "~11.0.5",
    "expo-build-properties": "~0.13.1",
    "expo-camera": "~16.0.18",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~5.0.20",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-intent-launcher": "~12.0.2",
    "expo-linear-gradient": "~14.0.2",
    "expo-system-ui": "~4.0.9",
    "expo-updates": "~0.27.5",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-call-detection": "^1.9.0",
    "react-native-svg": "15.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "dotenv-cli": "^11.0.0",
    "typescript": "~5.3.3"
  },
  "private": true
}
