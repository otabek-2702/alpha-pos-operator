{
  "name": "alphapos-operator-link",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "prebuild": "expo prebuild --platform android --clean",
    "tsc": "tsc --noEmit",
    "ios": "expo run:ios",
    "build:preview": "dotenv -e .env -- eas build --profile preview --platform android --non-interactive",
    "build:dev": "dotenv -e .env -- eas build --profile development --platform android --non-interactive",
    "build:prod": "dotenv -e .env -- eas build --profile production --platform android --non-interactive"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-build-properties": "~0.13.1",
    "expo-camera": "~16.0.18",
    "expo-dev-client": "~5.0.20",
    "expo-system-ui": "~4.0.9",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-call-detection": "^1.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "dotenv-cli": "^11.0.0",
    "typescript": "~5.3.3"
  },
  "private": true
}
