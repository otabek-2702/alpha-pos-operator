# Copy this file to ".env" and paste your Expo access token.
# The real ".env" is git-ignored — never commit it.
#
# Get a token: https://expo.dev/settings/access-tokens  ->  "Create token"
# (Personal Access Token. Treat it like a password.)
#
# Once set, `npm run build:preview` (etc.) authenticate as your account
# with no login prompt.

EXPO_TOKEN=
